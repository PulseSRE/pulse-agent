FROM registry.access.redhat.com/ubi9/python-312:latest

WORKDIR /opt/app-root/src

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
    'anthropic[vertex]>=0.52.0' \
    'kubernetes>=31.0.0' \
    'rich>=13.0.0' \
    'fastapi>=0.115.0' \
    'uvicorn[standard]>=0.34.0' \
    'websockets>=14.0'
